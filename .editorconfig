# EditorConfig — stryker-netx
# https://editorconfig.org/
# Roslyn-Analyzer reads this file (Roslynator + SonarAnalyzer.CSharp + Meziantou).
# Severity adjustments here are AUDIT-FÄHIG and require comment justification (CLAUDE.md).

root = true

# ============================================================================
# Universal defaults
# ============================================================================
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown,txt}]
trim_trailing_whitespace = false
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{xml,csproj,props,targets,slnx}]
indent_size = 2

# ============================================================================
# C# specific
# ============================================================================
[*.cs]
indent_size = 4
tab_width = 4

# Code style — body preferences
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent

# Var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# Modern syntax
csharp_style_inlined_variable_declaration = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# Null
csharp_style_unused_value_assignment_preference = discard_variable:suggestion
csharp_style_unused_value_expression_statement_preference = discard_variable:silent

# Using directives
csharp_using_directive_placement = outside_namespace:warning
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true

# Brace style
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Namespace declarations — file-scoped (modern)
csharp_style_namespace_declarations = file_scoped:warning

# Naming conventions
dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_rule.private_field_underscore.severity = warning
dotnet_naming_rule.private_field_underscore.symbols = private_fields
dotnet_naming_rule.private_field_underscore.style = camel_case_underscore

dotnet_naming_rule.constants_should_be_pascal_case.severity = warning
dotnet_naming_rule.constants_should_be_pascal_case.symbols = constants
dotnet_naming_rule.constants_should_be_pascal_case.style = pascal_case

# Symbol specs
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = *
dotnet_naming_symbols.interface.required_modifiers =

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.applicable_accessibilities = *
dotnet_naming_symbols.constants.required_modifiers = const

# Naming styles
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_style.camel_case_underscore.required_prefix = _
dotnet_naming_style.camel_case_underscore.capitalization = camel_case

# ============================================================================
# Severity adjustments — Stryker-specific defensive patterns
# Each adjustment requires a JUSTIFICATION COMMENT (CLAUDE.md ADR-004).
# ============================================================================

# AOT-related warnings — ADR-006: NativeAOT is not enforced in Sprint 1.
# These would otherwise force source-generator refactor of reflection-heavy paths.
dotnet_diagnostic.IL2026.severity = none  # RequiresUnreferencedCode — Reflection in Buildalyzer/Roslyn paths is intentional
dotnet_diagnostic.IL3050.severity = none  # RequiresDynamicCode — same rationale as IL2026
dotnet_diagnostic.IL2070.severity = none  # this-Type DynamicallyAccessedMembers — reflection-based mutator discovery
dotnet_diagnostic.IL2090.severity = none  # this-Generic DynamicallyAccessedMembers
dotnet_diagnostic.IL3053.severity = none  # AOT-incompatible call — see IL2026 rationale

# Stryker uses defensive Exception-catch at system boundaries (CLI entry, network calls)
# CLAUDE.md mandates: catch (Exception ex) when (ex is not OperationCanceledException) { ... }
# CA1031 would otherwise flag every such catch as too broad.
dotnet_diagnostic.CA1031.severity = suggestion  # Do not catch general exception types — overridden by intentional defensive pattern at system boundaries

# Stryker injects helpers (MutantControl.cs, MutantContext.cs) as embedded resources;
# they are loaded at runtime in user test-projects, not in stryker-netx itself.
# These should not be flagged as unused.
dotnet_diagnostic.CA1812.severity = suggestion  # Avoid uninstantiated internal classes — embedded resources legitimately appear unused

# XML doc comments are required on public APIs (CLAUDE.md PFLICHT) — but enforced phase-by-phase.
# Sprint 1 covers TFM-migration + Buildalyzer 9 + analyzer big-bang + test-stack migration + 17 projects.
# Adding ~6000 XML doc comments across all upstream-Stryker-NET-4.14.1 public members in Sprint 1
# would inflate the mega-sprint from 4–6 weeks to 10–14 weeks (50–80h extra). Stryker.NET upstream
# has NO XML docs — this is a Quality-Plus we add over upstream, but it requires its own dedicated
# work-stream. Plan: a dispatched-subagent "Public API Documentation Sprint" runs after Phase 7
# (Sprint 1.5 / Sprint 2-A), one subagent per module, generating XML doc from symbol bodies.
# Re-enable: when dispatched-subagent sprint completes (Sprint-1.5 close).
dotnet_diagnostic.CS1591.severity = none  # Missing XML comment — phased per Sprint-1.5 plan

# Sealed-by-default policy (CLAUDE.md)
dotnet_diagnostic.CA1852.severity = warning  # Seal internal types — supports sealed-default policy

# CA1720 (identifier contains type name) and CA1716 (identifier matches reserved keyword)
# DISABLED: Stryker public-API uses "String", "Single", "Guid" as Mutator-enum values, "Static",
# "End", "Case" as interface members. Renaming these would be a breaking change for library
# consumers (1:1-Portierung-Spirit per ADR-001/ADR-003 — Namespaces and public API preserved).
# These names match upstream Stryker.NET conventions (e.g., `Mutator.String` is part of the
# documented Mutator catalog). Re-evaluate only if upstream Stryker.NET ever renames them.
dotnet_diagnostic.CA1720.severity = none  # Identifier contains type name — Stryker public-API
dotnet_diagnostic.CA1716.severity = none  # Identifier matches reserved keyword — Stryker public-API

# CA1711 (identifier ends with type-suffix like "EventArgs", "EventHandler", "Collection")
# DISABLED: Stryker public-API uses suffix-conventions that match upstream Stryker.NET 4.14.1:
# - `TestNodeStateChangedEventArgs` is a JSON-RPC payload record, named `EventArgs` in upstream
# - `DiscoveryEventHandler` and `RunEventHandler` are VsTest event-listener classes
#   (implement Microsoft.VisualStudio.TestPlatform's ITestDiscoveryEventsHandler / ITestRunEventsHandler)
#   The suffix matches the *EventsHandler interface conventions, even though the classes don't derive from EventHandler.
# Renaming would be a breaking change for library consumers (1:1-Portierung-Spirit per ADR-001/ADR-003).
dotnet_diagnostic.CA1711.severity = none  # Identifier suffix — Stryker public-API matches VsTest event-handler conventions

# CA1848 + CA1873 — Phase 10.2 (Sprint 1 Modernization-Sweep): re-enabled as warning/error.
# Phase 10.2 ports all 233 logger calls in src/ from direct ILogger.LogX(...) invocations to
# the C# 12+ source-generator pattern via partial methods with [LoggerMessage] attributes.
# This eliminates the boxing + format-string-parse cost per call and makes log templates
# Roslyn-validated at compile-time.
dotnet_diagnostic.CA1848.severity = error  # Use LoggerMessage delegates — Phase 10.2 source-generator refactor
dotnet_diagnostic.CA1873.severity = error  # Avoid potentially expensive logging args — Phase 10.2 (twin of CA1848)

# Phase 10.3 — Modern C# idioms
# IDE0290: Use primary constructor — applied selectively where parameters map 1:1 to fields
#         without additional ctor logic; per-class judgment, no auto-fix.
# IDE0028 / IDE0300 / IDE0301 / IDE0302 / IDE0305 / IDE0306: Use collection expression `[...]`
#         instead of `new List<T>{...}` / `Array.Empty<T>()` / `new T[] {...}` — mechanical, safe.
dotnet_diagnostic.IDE0290.severity = suggestion  # Primary constructors — manually applied where appropriate
dotnet_diagnostic.IDE0028.severity = warning     # Collection initialization can be simplified
dotnet_diagnostic.IDE0300.severity = warning     # Collection initialization can be simplified (array)
dotnet_diagnostic.IDE0301.severity = warning     # Collection initialization can be simplified (empty array)
dotnet_diagnostic.IDE0302.severity = warning     # Collection initialization can be simplified (stackalloc)
dotnet_diagnostic.IDE0305.severity = warning     # Collection initialization can be simplified (toarray)
dotnet_diagnostic.IDE0306.severity = warning     # Collection expression — pre-existing IEnumerable

# ============================================================================
# Test-project specific overrides (Phase 7 onwards)
# ============================================================================
# Tests follow the xUnit convention `Method_Under_Test_Should_Do_X` for readability.
# CA1707 (no underscores in identifiers) conflicts with this widely-adopted pattern
# in the .NET test ecosystem. Disabling CA1707 ONLY for test projects keeps production
# code naming-compliant while permitting expressive test names.
[{tests,benchmarks,samples}/**/*.cs]
dotnet_diagnostic.CA1707.severity = none  # Underscores allowed in test/benchmark/sample method names
